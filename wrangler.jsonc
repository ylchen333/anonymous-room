{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "anonymous-room",
  "pages_build_output_dir": ".",
  "compatibility_date": "2026-07-16",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "anonymous-room-comments",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ]
}
